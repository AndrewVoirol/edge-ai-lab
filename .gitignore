# =============================================================================
# Edge AI Lab .gitignore
# =============================================================================

# --- Tuist-Generated Artifacts ---
# These are regenerated by `tuist generate` from Project.swift
*.xcodeproj/
*.xcworkspace/
Derived/

# Exception: Track Package.resolved for reproducible CI builds.
# This locks SPM dependency versions. To update:
#   xcodebuild -resolvePackageDependencies && commit the updated file.
!GemmaEdgeGallery.xcworkspace/xcshareddata/
!GemmaEdgeGallery.xcworkspace/xcshareddata/swiftpm/
!GemmaEdgeGallery.xcworkspace/xcshareddata/swiftpm/Package.resolved

# --- Model Files ---
# LLM weights are large (1.5GB+) and locally provisioned
# See CONTRIBUTING.md for model provisioning instructions
models/
*.litertlm

# --- Build Artifacts ---
build/
DerivedData/
*.xcresult
*.ipa
*.dSYM.zip
*.dSYM

# --- macOS ---
.DS_Store
*.swp
*~

# --- Xcode ---
xcuserdata/
*.xcscmblueprint
*.xccheckout

# --- Swift Package Manager ---
.build/
.package.resolved
Packages/

# --- Development Tooling ---
# Agent-specific configuration (not part of the project)
.antigravity/
.xcodebuildmcp/

# --- Profiling & Metrics ---
# Machine-local benchmark data (traces, CI result dumps)
metrics/
# But track the regression baselines and dashboard
!metrics/baselines.json
!metrics/DASHBOARD.md
default.profraw
*.trace

# --- Misc ---
*.log
*.tmp
