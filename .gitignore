# =============================================================================
# GemmaEdgeGallery .gitignore
# =============================================================================

# --- Tuist-Generated Artifacts ---
# These are regenerated by `tuist generate` from Project.swift
*.xcodeproj/
*.xcworkspace/
Derived/

# --- Model Files ---
# LLM weights are large (1.5GB+) and locally provisioned
# See DEVELOPING.md for model provisioning instructions
models/
*.litertlm

# --- Build Artifacts ---
build/
DerivedData/
*.xcresult
*.ipa
*.dSYM.zip
*.dSYM

# --- Fastlane (removed, but ignore any residual artifacts) ---
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# --- macOS ---
.DS_Store
*.swp
*~

# --- Xcode ---
xcuserdata/
*.xcscmblueprint
*.xccheckout

# --- Swift Package Manager ---
.build/
Packages/

# --- Misc ---
*.log
*.tmp
